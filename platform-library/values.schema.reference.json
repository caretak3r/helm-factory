{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "platform-library consumer values",
  "description": "Root-level values contract for a chart that depends on platform-library with import-values: [defaults]. Ship this as values.schema.json in the consuming chart (the scaffold generator does this automatically). It is NOT installed at the library root, because the library wraps its defaults under exports.defaults.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["Deployment", "StatefulSet", "DaemonSet"] }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": ["string", "number"] },
        "digest": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 0 },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "ports": { "type": "array", "items": { "type": "object" } }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "issuer": { "type": "string" }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": { "required": ["issuer"], "properties": { "issuer": { "minLength": 1 } } }
    },
    "mtls": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["STRICT", "PERMISSIVE", "DISABLE", "UNSET"] }
      }
    },
    "gatewayApi": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "podMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "cronJob": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "enableServiceLinks": { "type": "boolean" },
    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "apiVersions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "extraObjects": {
      "type": "object",
      "description": "Map of Kubernetes Kind -> list of object specs. Each spec is capability-negotiated and requires a name.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string" },
            "clusterScoped": { "type": "boolean" },
            "apiVersion": { "type": "string" },
            "labels": { "type": "object" },
            "annotations": { "type": "object" }
          }
        }
      }
    },
    "extraManifests": {
      "type": "array",
      "items": { "type": ["object", "string"] }
    }
  }
}
