{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "platform-library consumer values",
  "description": "Root-level values contract for a chart that depends on platform-library with import-values: [defaults]. Ship this as values.schema.json in the consuming chart (the scaffold generator does this automatically). It is NOT installed at the library root, because the library wraps its defaults under exports.defaults.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string", "enum": ["Deployment", "StatefulSet", "DaemonSet"] }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "required": ["repository"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": ["string", "number"], "not": { "const": "latest" }, "description": "Immutable image tag. Required unless image.digest is set; the floating tag 'latest' is rejected." },
        "digest": { "type": "string", "description": "Image digest (sha256:...). Preferred pin; overrides tag when both are set." },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never", ""], "description": "Empty string defers to global.imagePullPolicy, then IfNotPresent." }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 0 },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
        "externalName": { "type": "string", "description": "Required when type is ExternalName: the external DNS name the Service aliases (e.g. db.example.com). ExternalName Services render only type + externalName; ports and selector are omitted." },
        "ports": { "type": "array", "items": { "type": "object" } }
      },
      "if": { "properties": { "type": { "const": "ExternalName" } }, "required": ["type"] },
      "then": { "required": ["externalName"], "properties": { "externalName": { "minLength": 1 } } }
    },
    "secret": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "existingSecret": { "type": "string", "description": "Name of a pre-created Secret (External Secrets / Sealed Secrets / kubectl). When set the chart renders no Secret; mutually exclusive with data/stringData. Consume it via envVarsSecret or envVars valueFrom." },
        "type": { "type": "string" },
        "data": { "type": "object" },
        "stringData": { "type": "object", "description": "DISCOURAGED: plaintext secret material in values ends up in git and in Helm release manifests. Prefer existingSecret." }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "hostname": { "type": "string", "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$", "description": "RFC 1123 DNS subdomain (lowercase alphanumerics, '-', '.'); empty string disables host-based routing." },
        "tls": { "type": "boolean", "description": "Terminate TLS for ingress.hostname. secretName resolution: ingress.existingSecret when set; else the release-managed <fullname>-tls Secret when tlsSelfSigned.enabled or certificate.enabled (certificate.secretName wins if set); else the conventional <hostname>-tls, which must be provisioned separately." },
        "existingSecret": { "type": "string" },
        "secrets": { "type": "array", "items": { "type": "object" }, "description": "DISCOURAGED: inline TLS cert/key material in values. Prefer cert-manager (certificate block) or a pre-created Secret via existingSecret." }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"], "description": "Absolute count or percentage (e.g. 1 or \"50%\"). Mutually exclusive with maxUnavailable; empty string means unset. When neither is set the chart applies minAvailable: 1." },
        "maxUnavailable": { "type": ["integer", "string"], "description": "Absolute count or percentage (e.g. 1 or \"25%\"). Mutually exclusive with minAvailable; empty string means unset." }
      }
    },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" }, "description": "Pod topology spread constraints applied to the workload pod spec. Takes precedence over highAvailability.topologySpreadConstraints when non-empty." },
    "daemonSet": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tolerations": { "type": "array", "items": { "type": "object" }, "description": "Tolerations appended to the root-level tolerations. Applied only when workload.type is DaemonSet." }
      }
    },
    "certificate": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "issuer": { "type": "string" }
      },
      "if": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] },
      "then": { "required": ["issuer"], "properties": { "issuer": { "minLength": 1 } } }
    },
    "tlsSelfSigned": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "commonName": { "type": "string" },
        "dnsNames": { "type": "array", "items": { "type": "string" } },
        "validityDays": { "type": "integer", "minimum": 1, "description": "Certificate lifetime in days, applied when the cert is (re)generated." },
        "renewBeforeDays": { "type": "integer", "minimum": 0, "description": "Regenerate the self-signed cert when within this many days of its recorded expiry (platform/tls-not-after annotation) instead of reusing the looked-up Secret. A legacy Secret without that annotation regenerates once, acquiring rotation metadata." }
      }
    },
    "mtls": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "policy": { "type": "string", "enum": ["STRICT", "PERMISSIVE", "DISABLE", "UNSET"], "description": "Istio PeerAuthentication mTLS mode, rendered as spec.mtls.mode." },
        "allowedPrincipals": { "type": "array", "items": { "type": "string" } },
        "allowAllPrincipals": { "type": "boolean", "description": "Explicit opt-in: when true and allowedPrincipals is empty, the AuthorizationPolicy allows every mesh workload (cluster.local/ns/*/sa/*). Ignored when allowedPrincipals is non-empty." },
        "mode": false
      }
    },
    "gatewayApi": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "apiVersion": { "type": "string", "description": "Explicit apiVersion override for both routes. Leave empty (the default) so each route negotiates its Kind's apiVersion against the cluster (HTTPRoute: v1 then v1beta1; GRPCRoute: v1 then v1alpha2)." },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "httpRoute": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "parentRefs": { "type": "array", "items": { "type": "object" } }
          }
        },
        "grpcRoute": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "parentRefs": { "type": "array", "items": { "type": "object" } }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": { "const": true },
              "httpRoute": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] }
            },
            "required": ["enabled", "httpRoute"]
          },
          "then": {
            "anyOf": [
              { "properties": { "parentRefs": { "type": "array", "minItems": 1 } }, "required": ["parentRefs"] },
              { "properties": { "httpRoute": { "properties": { "parentRefs": { "type": "array", "minItems": 1 } }, "required": ["parentRefs"] } } }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "enabled": { "const": true },
              "grpcRoute": { "properties": { "enabled": { "const": true } }, "required": ["enabled"] }
            },
            "required": ["enabled", "grpcRoute"]
          },
          "then": {
            "anyOf": [
              { "properties": { "parentRefs": { "type": "array", "minItems": 1 } }, "required": ["parentRefs"] },
              { "properties": { "grpcRoute": { "properties": { "parentRefs": { "type": "array", "minItems": 1 } }, "required": ["parentRefs"] } } }
            ]
          }
        }
      ]
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "policyTypes": {
          "type": "array",
          "items": { "type": "string", "enum": ["Ingress", "Egress"] },
          "uniqueItems": true,
          "minItems": 1,
          "description": "NetworkPolicy spec.policyTypes; only Ingress/Egress are valid Kubernetes values."
        }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "podMonitor": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "cronJob": {
      "type": "object",
      "additionalProperties": true,
      "properties": { "enabled": { "type": "boolean" } }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string", "pattern": "^$|^[a-z0-9]([-a-z0-9]*[a-z0-9])?(\\.[a-z0-9]([-a-z0-9]*[a-z0-9])?)*$", "maxLength": 253, "description": "RFC 1123 DNS subdomain (lowercase alphanumerics, '-', '.'); empty string defers to the release-derived default name." },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "enableServiceLinks": { "type": "boolean" },
    "podSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "fsGroup": { "type": "integer", "minimum": 0 },
        "runAsUser": { "type": "integer", "minimum": 0 },
        "runAsGroup": { "type": "integer", "minimum": 0 },
        "runAsNonRoot": { "type": "boolean" },
        "seccompProfile": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string", "enum": ["RuntimeDefault", "Localhost", "Unconfined"] }
          }
        }
      }
    },
    "containerSecurityContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "runAsUser": { "type": "integer", "minimum": 0 },
        "runAsGroup": { "type": "integer", "minimum": 0 },
        "runAsNonRoot": { "type": "boolean" },
        "readOnlyRootFilesystem": { "type": "boolean" },
        "allowPrivilegeEscalation": { "type": "boolean" },
        "privileged": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "drop": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z_]+$" } },
            "add": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z_]+$" } }
          }
        },
        "seccompProfile": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string", "enum": ["RuntimeDefault", "Localhost", "Unconfined"] }
          }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "apiVersions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "allowClusterScopedExtras": { "type": "boolean", "description": "Opt-in gate: cluster-scoped Kinds in extraObjects (ClusterRole, ClusterRoleBinding, PriorityClass, StorageClass, webhooks, CRDs, ...) fail rendering unless this is true." },
    "extraObjects": {
      "type": "object",
      "description": "Map of Kubernetes Kind -> list of object specs. Each spec is capability-negotiated and requires a name.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string" },
            "clusterScoped": { "type": "boolean" },
            "apiVersion": { "type": "string" },
            "labels": { "type": "object" },
            "annotations": { "type": "object" }
          }
        }
      }
    },
    "extraManifests": {
      "type": "array",
      "items": { "type": ["object", "string"] }
    }
  }
}
